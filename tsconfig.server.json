{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Node",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist",
        "rootDir": "./server",
        "strict": true
    },
    "include": [
        "server/**/*"
    ],
    "exclude": [
        "node_modules"
    ]
}